# Gemini API Key
GEMINI_API_KEY=

# Authentication
JWT_SECRET=your_jwt_secret_here

# Optional: Supabase for Persistent Storage (Recommended for Production)
# If these are provided, the app will use Supabase instead of local SQLite.
# Get these from your Supabase project settings (Settings -> API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
